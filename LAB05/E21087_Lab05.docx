2)CREATE TABLE Convocation (
    ConvocationRegNo INT PRIMARY KEY,
    RegNo INT,
    LastName VARCHAR(50),
    Address VARCHAR(100),
    Age INT,
    FOREIGN KEY (RegNo) REFERENCES Student(RegNo)
);


3)

DELIMITER //

CREATE PROCEDURE RegisterStudent(
    IN p_ConvocationRegNo INT,
    IN p_RegNo INT,
    IN p_LastName VARCHAR(50),
    IN p_Address VARCHAR(100),
    IN p_Age INT
)
BEGIN
    -- Insert into Convocation table
    INSERT INTO Convocation (ConvocationRegNo, RegNo, LastName, Address, Age)
    VALUES (p_ConvocationRegNo, p_RegNo, p_LastName, p_Address, p_Age);
    
    -- Update Student table
    UPDATE Student
    SET ConvocationRegNo = p_ConvocationRegNo
    WHERE RegNo = p_RegNo;
END //

DELIMITER ;


4)
CALL RegisterStudent(1, 154, 'Perera', 'Colombo', 24);
CALL RegisterStudent(2, 118, 'Silva', 'Kandy', 23);
CALL RegisterStudent(3, 147, 'Khan', 'Jaffna', 22);
CALL RegisterStudent(4, 379, 'Fernando', 'Galle', 24);
CALL RegisterStudent(5, 155, 'Senanayake', 'Kurunegala', 23);


5)
CREATE VIEW Registered AS
SELECT s.Name, s.RegNo, s.GPA, s.ConvocationRegNo, c.Address, c.Age
FROM Student s
JOIN Convocation c ON s.RegNo = c.RegNo;


6)

CREATE VIEW NotRegistered AS
SELECT s.Name, s.RegNo, s.GPA, '' AS Address, NULL AS Age
FROM Student s
WHERE s.ConvocationRegNo IS NULL;


7)
CREATE TABLE LateRegistration (
    ConvocationRegNo INT PRIMARY KEY,
    RegNo INT,
    LastName VARCHAR(50),
    Address VARCHAR(100),
    Age INT,
    FOREIGN KEY (RegNo) REFERENCES Student(RegNo)
);


8)
DELIMITER //

CREATE TRIGGER AfterLateRegistration
AFTER INSERT ON LateRegistration
FOR EACH ROW
BEGIN
    UPDATE Student
    SET ConvocationRegNo = NEW.ConvocationRegNo
    WHERE RegNo = NEW.RegNo;
END //

DELIMITER ;


9)
